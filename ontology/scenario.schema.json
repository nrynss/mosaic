{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/scenario/v1.0.0",
  "title": "Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scenario_id", "version", "title", "dataset_manifest_id", "beats"],
  "properties": {
    "schema_version": { "const": "1.0.0" }, "scenario_id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "title": { "type": "string", "minLength": 1 }, "dataset_manifest_id": { "type": "string", "minLength": 1 },
    "beats": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["beat_id", "order", "raw_event_id"], "properties": { "beat_id": { "type": "string", "minLength": 1 }, "order": { "type": "integer", "minimum": 1 }, "raw_event_id": { "type": "string", "minLength": 1 }, "delay_ms": { "type": "integer", "minimum": 0 } } } }
  }
}
