{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/location/v1.0.0",
  "title": "Location",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "location_id", "label"],
  "properties": { "schema_version": { "const": "1.0.0" }, "location_id": { "type": "string", "minLength": 1 }, "label": { "type": "string", "minLength": 1 }, "address": { "type": "string" }, "latitude": { "type": "number", "minimum": -90, "maximum": 90 }, "longitude": { "type": "number", "minimum": -180, "maximum": 180 } }
}
