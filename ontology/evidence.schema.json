{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/evidence/v1.0.0",
  "title": "Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "target_kind", "target_id", "explanation", "created_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" }, "evidence_id": { "type": "string", "minLength": 1 },
    "target_kind": { "enum": ["raw_event", "canonical_event", "state_fact", "insight"] }, "target_id": { "type": "string", "minLength": 1 },
    "json_pointer": { "type": "string", "pattern": "^/" }, "explanation": { "type": "string", "minLength": 1 }, "created_at": { "type": "string", "format": "date-time" }
  }
}
