{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/insight/v1.0.0",
  "title": "Insight",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "insight_id", "state_revision", "lifecycle_status", "assertions", "evidence", "confidence", "created_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" }, "insight_id": { "type": "string", "minLength": 1 }, "state_revision": { "type": "integer", "minimum": 1 },
    "lifecycle_status": { "enum": ["active", "obsolete"] }, "assertions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence_ref" } }, "confidence": { "$ref": "#/$defs/confidence" },
    "supersedes_insight_id": { "type": "string", "minLength": 1 }, "obsolete_reason": { "type": "string", "minLength": 1 }, "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "evidence_ref": { "type": "object", "additionalProperties": false, "required": ["target_kind", "target_id", "explanation"], "properties": { "target_kind": { "enum": ["raw_event", "canonical_event", "state_fact", "insight"] }, "target_id": { "type": "string", "minLength": 1 }, "json_pointer": { "type": "string", "pattern": "^/" }, "explanation": { "type": "string", "minLength": 1 } } },
    "confidence": { "type": "object", "additionalProperties": false, "required": ["source_quality", "transformation_certainty", "reasoning_support", "basis"], "properties": { "source_quality": { "enum": ["low", "medium", "high"] }, "transformation_certainty": { "enum": ["low", "medium", "high"] }, "reasoning_support": { "enum": ["low", "medium", "high"] }, "basis": { "type": "string", "minLength": 1 } } }
  }
}
