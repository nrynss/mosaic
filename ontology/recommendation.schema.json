{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/recommendation/v1.0.0",
  "title": "Recommendation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "recommendation_id", "state_revision", "text", "evidence", "created_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" }, "recommendation_id": { "type": "string", "minLength": 1 }, "state_revision": { "type": "integer", "minimum": 1 },
    "text": { "type": "string", "minLength": 1, "pattern": "(?i)^(consider|review|verify)\\b" }, "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence_ref" } },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": { "evidence_ref": { "type": "object", "additionalProperties": false, "required": ["target_kind", "target_id", "explanation"], "properties": { "target_kind": { "enum": ["raw_event", "canonical_event", "state_fact", "insight"] }, "target_id": { "type": "string", "minLength": 1 }, "json_pointer": { "type": "string", "pattern": "^/" }, "explanation": { "type": "string", "minLength": 1 } } } }
}
