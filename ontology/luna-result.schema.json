{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.local/ontology/luna-result/v1.0.0",
  "title": "LunaResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "luna_result_id", "raw_event_id", "status", "created_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "luna_result_id": { "type": "string", "minLength": 1 },
    "raw_event_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["accepted", "repaired", "quarantined", "rejected"] },
    "canonical_event_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "repair": { "$ref": "#/$defs/repair" },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_ref" }, "minItems": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    { "if": { "properties": { "status": { "enum": ["accepted", "repaired"] } } }, "then": { "required": ["canonical_event_id", "evidence"] } },
    { "if": { "properties": { "status": { "const": "repaired" } } }, "then": { "required": ["repair"] } },
    { "if": { "properties": { "status": { "enum": ["quarantined", "rejected"] } } }, "then": { "required": ["reason"] } }
  ],
  "$defs": {
    "repair": { "type": "object", "additionalProperties": false, "required": ["method", "fields"], "properties": { "method": { "type": "string", "minLength": 1 }, "fields": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["json_pointer", "original", "replacement"], "properties": { "json_pointer": { "type": "string", "pattern": "^/" }, "original": {}, "replacement": {} } } } } },
    "evidence_ref": { "type": "object", "additionalProperties": false, "required": ["target_kind", "target_id", "explanation"], "properties": { "target_kind": { "enum": ["raw_event", "canonical_event", "state_fact", "insight"] }, "target_id": { "type": "string", "minLength": 1 }, "json_pointer": { "type": "string", "pattern": "^/" }, "explanation": { "type": "string", "minLength": 1 } } }
  }
}
